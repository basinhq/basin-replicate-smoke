{
  "pipeline": "${pipeline}",
  "mode": "append",
  "engine": {"snapshot_mode": "initial"},
  "source": {"kind": "postgres", "options": {
    "host": "${postgres_host}",
    "port": ${postgres_port},
    "database": "${postgres_database}",
    "user": "${postgres_user}",
    "password": "${postgres_password}",
    "tls": "disable",
    "publication": "${publication}",
    "publication_mode": "create_if_missing",
    "slot": "${slot}",
    "slot_mode": "create_if_missing",
    "include_tables": ["${schema}.events"]
  }},
  "sink": {"kind": "clickhouse", "options": {"endpoint": "${clickhouse_endpoint}",
    "user": "${clickhouse_user}",
    "password": "${clickhouse_password}",
    "database": "${clickhouse_database}"}},
  "state": {"kind": "sqlite", "options": {"path": "${state_dir}/state.db"}},
  "worker": {"lease_overlap": "skip_if_held"}
}
