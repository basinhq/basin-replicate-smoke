{
  "pipeline": "${pipeline}",
  "engine": {"snapshot_mode": "no_data"},
  "source": {"kind": "query", "options": {
    "connection": {
      "host": "${postgres_host}",
      "port": ${postgres_port},
      "database": "${postgres_database}",
      "user": "${postgres_user}",
      "tls": "disable"
    },
    "table": "${schema}.orders",
    "mode": "incrementing",
    "incrementing": {"column": "id", "unique": true, "strictly_increasing": true},
    "schema_change_policy": "safe_additions"
  }},
  "sink": {"kind": "ducklake", "options": {
    "storage": {"type": "local", "path": "${catalog_dir}/data"},
    "catalog": {"type": "duckdb", "path": "${catalog_dir}/metadata.duckdb"},
    "extension_directory": "${ext_dir}"
  }},
  "state": {"kind": "sqlite", "options": {"path": "${state_dir}/state.db"}},
  "worker": {"lease_overlap": "skip_if_held"}
}
