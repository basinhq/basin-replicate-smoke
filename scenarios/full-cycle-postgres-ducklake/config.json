{
  "pipeline": "${pipeline}",
  "engine": {"snapshot_mode": "initial"},
  "source": {"kind": "postgres", "options": {
    "host": "${postgres_host}",
    "port": ${postgres_port},
    "database": "${postgres_database}",
    "user": "${postgres_user}",
    "tls": "disable",
    "publication": "${publication}",
    "publication_mode": "create_if_missing",
    "slot": "${slot}",
    "slot_mode": "create_if_missing",
    "include_tables": ["${schema}.orders"]
  }},
  "sink": {"kind": "ducklake", "options": {
    "storage": {"type": "local", "path": "${catalog_dir}/data"},
    "catalog": {"type": "duckdb", "path": "${catalog_dir}/metadata.duckdb"},
    "extension_directory": "${ext_dir}"
  }},
  "state": {"kind": "sqlite", "options": {"path": "${state_dir}/state.db"}},
  "worker": {"lease_overlap": "skip_if_held"}
}
